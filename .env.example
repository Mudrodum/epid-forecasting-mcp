# Dataset included in the MCP server image.
EPID_DATA_PATH=/app/data/influenza_weather_spb_dataset.csv

# S3-compatible artifact storage. These names follow dataset-collection-mcp-server.
ENDPOINT_URL=http://localhost:9000
ACCESS_KEY=your-access-key
SECRET_KEY=your-secret-key
BUCKET_NAME=your-bucket-name

# Temporary client download links for forecast artifacts: 1 hour.
PRESIGNED_URL_EXPIRATION_SECONDS=3600

# NII influenza DB CSV endpoint. The auth token is required only for DB-backed tools.
# Do not commit real token values.
INFLUENZA_DB_AUTH_TOKEN=your-influenza-db-token
INFLUENZA_DB_TIMEOUT_SECONDS=60
# Optional endpoint overrides; defaults match the NII influenza CSV report contract.
# INFLUENZA_DB_BASE_URL=https://db.influenza.spb.ru/scripts/report/rmancgi.exe
# INFLUENZA_DB_REPORT_NAME=get_csv
# INFLUENZA_DB_REPORT_ID=aripcr
