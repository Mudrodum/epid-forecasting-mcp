# Dataset included in the MCP server image.
EPID_DATA_PATH=/app/data/influenza_weather_spb_dataset.csv

# S3-compatible artifact storage. These names follow dataset-collection-mcp-server.
ENDPOINT_URL=http://localhost:9000
ACCESS_KEY=your-access-key
SECRET_KEY=your-secret-key
BUCKET_NAME=your-bucket-name

# Temporary client download links for forecast artifacts: 1 hour.
PRESIGNED_URL_EXPIRATION_SECONDS=3600
